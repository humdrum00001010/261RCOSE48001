{<<"name">>,<<"ex_mcp">>}.
{<<"version">>,<<"0.10.0">>}.
{<<"description">>,
 <<"Elixir implementation of MCP and ACP. Build MCP clients/servers with tools, resources, prompts over stdio, HTTP/SSE, and BEAM. Control coding agents via ACP with adapters for Claude Code, Codex, and more.">>}.
{<<"elixir">>,<<"~> 1.17">>}.
